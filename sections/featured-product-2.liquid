<div id="shopify-section-{{ section.id }}" class="shopify-section index-section">
  <div data-section-id="{{ section.id }}" data-section-type="featured-product">
    <div class="page-width">
      <div class="section-header">
        <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      </div>

      {% assign product = all_products[section.settings.product] %}
      {% if product %}
        <div class="grid">
          <div class="grid__item medium-up--one-half">
            {% if product.featured_image %}
              <a href="{{ product.url }}" class="featured-product__image-link">
                <div class="image-wrap" style="height: 0; padding-bottom: 100%;">
                  <img
                    class="featured-product__image"
                    src="{{ product.featured_image | img_url: '720x' }}"
                    srcset="{{ product.featured_image | img_url: '360x' }} 360w, {{ product.featured_image | img_url: '720x' }} 720w, {{ product.featured_image | img_url: '1080x' }} 1080w"
                    sizes="(max-width: 589px) 100vw, 50vw"
                    alt="{{ product.featured_image.alt | escape }}"
                  >
                </div>
              </a>
            {% endif %}
          </div>

          <div class="grid__item medium-up--one-half">
            <div class="featured-product__meta">
              {% if product.vendor != blank %}
                <p class="featured-product__vendor">{{ product.vendor }}</p>
              {% endif %}
              <h3 class="featured-product__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              {% if product.available %}
                <p class="featured-product__price">{{ product.price | money }}</p>
              {% else %}
                <p class="featured-product__price">{{ 'products.product.sold_out' | t }}</p>
              {% endif %}
              {% if product.description != blank %}
                <div class="featured-product__description rte">{{ product.description | strip_html | truncate: 220 }}</div>
              {% endif %}
              <a href="{{ product.url }}" class="btn btn--secondary featured-product__button">{{ section.settings.cta_text }}</a>
            </div>
          </div>
        </div>
      {% else %}
        <div class="page-width text-center">
          <p>No product selected. Please choose a product in the section settings.</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured product 2",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Featured product"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Shop product"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Featured product 2",
      "category": "Product"
    }
  ]
}
{% endschema %}
