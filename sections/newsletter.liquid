<div id="shopify-section-{{ section.id }}" class="shopify-section">
  <div data-section-id="{{ section.id }}" data-section-type="newsletter">
    <div class="newsletter-section newsletter-{{ section.id }}" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
      <div class="page-width text-center">
        <p class="h3">{{ section.settings.heading }}</p>
        {% if section.settings.description != blank %}
          <div class="rte">{{ section.settings.description }}</div>
        {% endif %}

        <form method="post" action="/contact#newsletter-{{ section.id }}" id="newsletter-{{ section.id }}" accept-charset="UTF-8" class="contact-form">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="{{ section.settings.tags }}">
          <input type="hidden" name="contact[context]" value="newsletter">

          <div class="input-group newsletter__input-group">
            <label for="Email-{{ section.id }}" class="hidden-label">{{ section.settings.email_label }}</label>
            <input
              type="email"
              name="contact[email]"
              id="Email-{{ section.id }}"
              class="input-group-field newsletter__input"
              placeholder="{{ section.settings.email_placeholder }}"
              autocorrect="off"
              autocapitalize="off"
              required
            >
            <div class="input-group-btn">
              <button type="submit" class="btn newsletter__button">
                <span>{{ section.settings.button_text }}</span>
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign up for our newsletter"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Subscribe to get special offers, free giveaways, and once-in-a-lifetime deals."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email field label",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "tags",
      "label": "Customer tags",
      "default": "prospect,newsletter"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#384734"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#fafafa"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Newsletter",
      "category": "Newsletter"
    }
  ]
}
{% endschema %}
