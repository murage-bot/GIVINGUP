<div id="shopify-section-{{ section.id }}" class="shopify-section index-section">
  <div data-section-id="{{ section.id }}" data-section-type="testimonials">
    <div class="page-width text-center">
      <div class="section-header">
        <h2 class="section-header__title">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="section-header__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="testimonials-wrapper">
          <div class="testimonials-slider">
            {% for block in section.blocks %}
              <div class="testimonials-slide">
                <blockquote class="testimonials-slider__text">
                  <span class="quote-icon"><svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-quote" viewBox="0 0 41 35"><path d="M10.208 17.711h6.124v16.332H0V21.684C0 8.184 5.444.956 16.332 0v6.125c-4.083 1.14-6.124 4.414-6.124 9.82v1.766zm24.498 0h6.124v16.332H24.498V21.684C24.498 8.184 29.942.956 40.83 0v6.125c-4.083 1.14-6.124 4.414-6.124 9.82v1.766z" fill="currentColor" fill-rule="evenodd"></path></svg></span>
                  <div class="rte-setting text-spacing">{{ block.settings.quote | escape | newline_to_br }}</div>
                  {% if block.settings.author != blank %}
                    <cite>{{ block.settings.author }}</cite>
                  {% endif %}
                </blockquote>
              </div>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div class="page-width text-center">
          <p>Add testimonials in the section settings to display them here.</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What customers say about us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": ""
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "Testimonials"
    }
  ]
}
{% endschema %}
